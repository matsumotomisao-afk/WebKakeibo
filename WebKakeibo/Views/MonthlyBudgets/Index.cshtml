@model IEnumerable<WebKakeibo.Models.MonthlyBudget>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.YearNum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MonthNum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BudgetAmount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.YearNum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MonthNum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BudgetAmount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.User.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MonthlyBudgetId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MonthlyBudgetId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MonthlyBudgetId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
